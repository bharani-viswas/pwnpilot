*.key
*.pem
*.p12
# Contains LLM API keys, database credentials, and sensitive settings
config.yaml
# Local config overrides with secrets
config.local.yaml
# Local user directory with keys, config, databases
~/.pwnpilot/

# Rules of Engagement documents (confidential)
# ⚠️ CRITICAL: ROE files contain sensitive authorization details and should never be committed!
roe.yaml
roe.local.yaml
*.roe.yaml
*.roe.yml
roe_*.yaml
/roe/
# EXCEPTION: roe.template.yaml and examples/roe.*.yaml are safe to commit (templates only, no secrets)

